---
import { withBase } from '../../utils/paths';
import { Icon } from 'astro-icon/components';
---

<div class="py-16 max-w-3xl mx-auto">
  <div class="relative p-8 md:p-10 rounded-2xl bg-gradient-to-r from-hero/[0.06] to-hero/[0.02] border border-hero/10 text-center overflow-hidden">
    <div class="absolute inset-0 opacity-30 pointer-events-none" aria-hidden="true">
      <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-64 h-64 bg-hero/10 rounded-full blur-[80px]"></div>
    </div>
    <div class="relative">
      <h3 class="text-xl md:text-2xl font-semibold text-white mb-3">¿Sabés qué necesita tu negocio?</h3>
      <p class="text-white/50 text-sm md:text-base mb-6 max-w-lg mx-auto">Dejame tus datos y te contacto para definir el mejor camino.</p>
      <a href={withBase('/contact')} class="inline-flex items-center gap-2 bg-hero text-white font-semibold px-7 py-3.5 rounded-xl hover:bg-hero/90 transition hover:shadow-xl hover:shadow-hero/20 group">
        Solicitar consulta gratuita
        <Icon name="heroicons:arrow-right" size={16} class="text-white group-hover:translate-x-0.5 transition-transform" />
      </a>
    </div>
  </div>
</div>
