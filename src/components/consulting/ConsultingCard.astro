---
import { Icon } from 'astro-icon/components';
import CardGlow from '../global/CardGlow.astro';

interface Props {
  title: string;
  description: string;
  icon?: string;
}

const { title, description, icon } = Astro.props;
---
<div class="group relative p-8 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-hero/30 transition duration-500 overflow-hidden card-entry">
  <CardGlow />
  <div class="absolute bottom-0 left-6 right-6 h-0.5 bg-hero/40 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
  {icon && (
    <div class="relative w-14 h-14 rounded-xl bg-gradient-to-br from-hero/15 to-hero/5 border border-hero/20 flex items-center justify-center mb-5 group-hover:from-hero/25 group-hover:to-hero/10 group-hover:border-hero/30 group-hover:scale-110 transition duration-300">
      <Icon name={icon} size={28} class="text-hero" />
    </div>
  )}
  <div class="relative">
    <h3 class="text-lg font-semibold text-white group-hover:text-hero transition-colors mb-3">{title}</h3>
    <p class="text-white/50 text-sm leading-relaxed">{description}</p>
  </div>
</div>