---
import SectionTitle from './SectionTitle.astro';
import StackGrid from './StackGrid.astro';
import { techStack } from '../../data/tech-icons';
import type { TechCategory } from '../../data/tech-icons';

interface Props {
  accent?: 'purple' | 'hylian' | 'amber';
}

const { accent = 'hylian' } = Astro.props;
---

<section class="py-24 md:py-32 bg-white/[0.01] border-y border-white/5">
  <div class="max-w-7xl mx-auto px-6 md:px-8">
    <SectionTitle
      title="Stack Tecnológico"
      description="Herramientas, lenguajes y plataformas con las que trabajo día a día."
    />

    <div class="mt-12 space-y-10">
      {(['Lenguajes', 'Frameworks', 'Testing', 'Data & Bases de Datos', 'Herramientas', 'DevOps & Cloud'] as TechCategory[]).map((cat, i) => (
        <StackGrid items={techStack} category={cat} accent={accent} index={i} />
      ))}
    </div>
  </div>
</section>
