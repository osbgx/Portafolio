---
interface Props {
  title: string;
  description?: string;
  centered?: boolean;
  id?: string;
  level?: 'h1' | 'h2';
}

const { title, description, centered = true, id, level = 'h2' } = Astro.props;
---

<div class={`mb-12 section-title ${centered ? 'text-center' : ''}`} id={id}>
  {level === 'h1' ? (
    <h1 class="text-3xl md:text-4xl font-bold text-white">{title}</h1>
  ) : (
    <h2 class="text-3xl md:text-4xl font-bold text-white">{title}</h2>
  )}
  {description && (
    <p class="text-white/50 text-lg mt-3 max-w-2xl mx-auto">{description}</p>
  )}
</div>

<style>
  .section-title {
    opacity: 0;
    transform: translateY(15px);
    animation: sectionTitleIn 0.5s ease-out forwards;
  }

  @keyframes sectionTitleIn {
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }
</style>
