---
import { headerThemes } from '../../data/themes';
import { Icon } from 'astro-icon/components';
import { mainNav } from '../../data/navigation';
import { withBase } from '../../utils/paths';

interface Props {
  theme?: string;
}

const { theme = 'default' } = Astro.props;

const t = headerThemes[theme] || headerThemes.default;

const navLinkClass = 'px-3 py-2 text-sm text-white/50 hover:text-white hover:bg-white/5 rounded-lg transition';
const dropdownLinkClass = 'block px-4 py-2 text-sm text-white/50 hover:text-white hover:bg-white/5 transition';
const mobileLinkClass = 'menu-link block text-lg text-white/50 hover:text-white py-3 px-4 rounded-xl hover:bg-white/5 transition';
const mobileSubLinkClass = 'menu-link block text-white/50 hover:text-white py-2.5 px-4 rounded-xl hover:bg-white/5 transition';
---

<header class={`fixed top-0 left-0 right-0 z-50 bg-carbon/90 backdrop-blur-md border-b ${t.border} ${t.font}`}>
  <nav class="max-w-7xl mx-auto px-6 md:px-8 flex items-center justify-between h-16">
    <a href={withBase('/')} class="flex items-center gap-2 group" data-umami-event="nav_home_logo">
      <span class={`w-8 h-8 ${t.logo} overflow-hidden flex items-center justify-center font-bold text-sm transition`}>
        {theme === 'about' ? '🐱' : '>_'}
      </span>
      <span class={`font-semibold text-white/90 hidden sm:block ${t.font}`}>Osmar Bogarín</span>
    </a>

    <div class={`hidden lg:flex items-center gap-1 ${t.font}`}>
      {mainNav.map((item) => {
        if (item.type === 'link') {
          return <a href={withBase(item.href)} class={navLinkClass} data-umami-event={`nav_${item.label.toLowerCase().replaceAll(' ', '_')}`}>{item.label}</a>;
        }
        if (item.type === 'dropdown') {
          return (
            <div class="relative group">
              <button class="px-3 py-2 text-sm text-white/50 hover:text-white hover:bg-white/5 rounded-lg transition flex items-center gap-1 cursor-pointer" aria-haspopup="true" aria-expanded="false" data-umami-event="nav_services_open">
                {item.label}
                <Icon name="heroicons:chevron-down" size={12} class="mt-0.5 group-hover:-rotate-180 transition-transform" />
              </button>
              <div class="absolute top-full left-0 w-44 bg-carbon/95 backdrop-blur-xl border border-white/10 rounded-xl py-2 shadow-xl opacity-0 invisible group-hover:opacity-100 group-hover:visible group-focus-within:opacity-100 group-focus-within:visible data-[dropdown-open=true]:opacity-100 data-[dropdown-open=true]:visible transition duration-200">
                {item.links.map((sub) => (
                  <a href={withBase(sub.href)} class={dropdownLinkClass} data-umami-event={`nav_service_${sub.label.toLowerCase().replaceAll(' ', '_')}`}>{sub.label}</a>
                ))}
              </div>
            </div>
          );
        }
        return null;
      })}
    </div>

    <div class="flex items-center gap-3">
      <a href={withBase('/contact')} class={`hidden sm:inline-flex ${t.cta} text-sm font-semibold px-5 py-2 transition`} data-umami-event="nav_contact_cta">
        Contáctame
      </a>
        <button id="menu-toggle" class="lg:hidden w-9 h-9 flex items-center justify-center rounded-lg border border-white/10 hover:bg-white/5 transition" aria-label="Abrir menú" data-umami-event="mobile_menu_toggle">
          <svg id="menu-icon-hamburger" class="w-5 h-5 text-white/70" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M4 6h16M4 12h16M4 18h16"/>
          </svg>
          <svg id="menu-icon-close" class="w-5 h-5 text-white/70 hidden" fill="none" viewBox="0 0 24 24" stroke="currentColor" stroke-width="2">
            <path stroke-linecap="round" stroke-linejoin="round" d="M6 18L18 6M6 6l12 12"/>
          </svg>
      </button>
    </div>
  </nav>
</header>

<div id="mobile-overlay" class="fixed inset-0 z-40 hidden lg:hidden bg-carbon/90" aria-hidden="true">
  <div id="mobile-menu" class="overflow-y-auto py-16 max-h-screen">
    <div class={`flex flex-col px-6 py-6 space-y-1 max-w-md mx-auto ${t.font}`}>
      {mainNav.map((item) => {
        if (item.type === 'link') {
          return <a href={withBase(item.href)} class={mobileLinkClass} data-umami-event={`mobile_nav_${item.label.toLowerCase().replaceAll(' ', '_')}`}>{item.label}</a>;
        }
        if (item.type === 'dropdown') {
          return (
            <div>
              <button id="services-toggle" class="w-full flex items-center justify-between text-lg text-white/50 hover:text-white py-3 px-4 rounded-xl hover:bg-white/5 transition" aria-controls="services-sub" aria-expanded="false" data-umami-event="mobile_nav_services_open">
                {item.label}
                <Icon name="heroicons:chevron-down" size={16} id="services-chevron" class="transition-transform" />
              </button>
              <div id="services-sub" class="hidden pl-6 space-y-0.5 pb-1">
                {item.links.map((sub) => (
                  <a href={withBase(sub.href)} class={mobileSubLinkClass} data-umami-event={`mobile_nav_service_${sub.label.toLowerCase().replaceAll(' ', '_')}`}>{sub.label}</a>
                ))}
              </div>
            </div>
          );
        }
        return null;
      })}

      <div class="pt-6 px-4">
        <a href={withBase('/contact')} class={`menu-link block text-center ${t.mobileCta} font-semibold px-6 py-3.5 transition`} data-umami-event="mobile_nav_contact_cta">
          Contáctame
        </a>
      </div>
    </div>
  </div>
</div>

<script>
  import { setupHeader } from '../../scripts/header';
  setupHeader();
</script>
