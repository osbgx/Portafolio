---
import MobileLayout from '../layouts/MobileLayout.astro';
import SectionTitle from '../components/global/SectionTitle.astro';
import ProjectCard from '../components/global/ProjectCard.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/paths';
import { iconColors, toolkit, capabilities, capabilityAccents, platforms, workflow } from '../data/mobile';
import CardGlow from '../components/global/CardGlow.astro';
import '../styles/mobile.css';

const allProjects = (await getCollection('projects')).map((p) => ({ ...p.data, id: p.slug }));
const mobileProjects = allProjects.filter((p) => (p.pages ?? []).includes('movil'));
const sortedProjects = [...mobileProjects].sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const featuredProject = sortedProjects[0];
const secondaryMobileProjects = allProjects
  .filter((p) => (p.featuredIn ?? []).includes('movil'))
  .filter((p) => p.id !== featuredProject?.id)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
---

<MobileLayout title="Desarrollo Móvil" description="Apps para tu negocio: herramientas internas, paneles de gestión y soluciones a medida con Supabase, Budibase, Kotlin y React Native.">
  <!-- Hero -->
  <section class="min-h-[80vh] sm:min-h-screen relative overflow-hidden flex items-center justify-center bg-dark-surface">
    <div class="absolute inset-0 bg-gradient-to-br from-purple-500/[0.04] via-transparent to-teal-500/[0.03] pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-400/20 to-transparent"></div>
    <div class="absolute top-32 -left-24 w-64 h-64 sm:w-80 sm:h-80 bg-purple-500/[0.05] rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute bottom-20 -right-24 w-64 h-64 sm:w-80 sm:h-80 bg-teal-400/[0.05] rounded-full blur-[100px] pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-96 h-96 bg-purple-500/[0.02] rounded-full blur-[120px] pointer-events-none lg:hidden"></div>

    <!-- Floating dots -->
    <div class="absolute inset-0 pointer-events-none overflow-hidden">
      <div class="hero-dot" style="top:15%;left:10%;width:2px;height:2px;--d:0s;--dur:4s"></div>
      <div class="hero-dot" style="top:25%;left:75%;width:3px;height:3px;--d:1s;--dur:5s"></div>
      <div class="hero-dot" style="top:50%;left:20%;width:2px;height:2px;--d:0.5s;--dur:6s"></div>
      <div class="hero-dot" style="top:65%;left:80%;width:1.5px;height:1.5px;--d:2s;--dur:4.5s"></div>
      <div class="hero-dot" style="top:80%;left:35%;width:2px;height:2px;--d:1.5s;--dur:5.5s"></div>
      <div class="hero-dot" style="top:35%;left:55%;width:2.5px;height:2.5px;--d:3s;--dur:7s"></div>
    </div>

    <!-- Decorative phone watermark (mobile) -->
    <div class="absolute right-0 bottom-0 w-48 h-48 sm:w-64 sm:h-64 opacity-[0.02] lg:hidden pointer-events-none overflow-hidden">
      <Icon name="heroicons:device-phone-mobile" class="w-full h-full text-white" />
    </div>
    <div class="absolute left-0 top-0 w-40 h-40 sm:w-56 sm:h-56 opacity-[0.015] lg:hidden pointer-events-none overflow-hidden rotate-12 -translate-x-12 -translate-y-12">
      <Icon name="heroicons:square-2-stack" class="w-full h-full text-white" />
    </div>

    <div class="relative z-10 w-full max-w-7xl mx-auto px-5 sm:px-8 lg:px-8">
      <div class="flex flex-col lg:flex-row items-center gap-8 sm:gap-10 lg:gap-16">
        <div class="w-full max-w-xl text-center lg:text-left py-8 sm:py-14 lg:py-20 space-y-5 sm:space-y-6 lg:space-y-8">
          <div class="hero-entry hero-badge inline-flex items-center gap-0 rounded-full bg-gradient-to-r from-purple-500/10 to-teal-500/10 border border-purple-400/20 text-xs sm:text-sm mx-auto lg:mx-0">
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-purple-300">
              <Icon name="heroicons:device-phone-mobile" size={14} />
              Nativo
            </span>
            <span class="w-px h-4 bg-purple-400/20"></span>
            <span class="inline-flex items-center gap-1.5 px-3 py-1.5 text-teal-300">
              <Icon name="heroicons:square-2-stack" size={14} />
              Multiplataforma
            </span>
          </div>
          <h1 class="hero-entry hero-headline text-5xl md:text-6xl lg:text-7xl font-bold text-white tracking-tight leading-[1.1] text-center lg:text-left">
            <span class="block">De la <span class="bg-gradient-to-r from-purple-400 via-teal-400 to-pink-400 bg-clip-text text-transparent">idea</span></span>
            <span class="block">a la <span class="bg-gradient-to-r from-purple-400 via-teal-400 to-pink-400 bg-clip-text text-transparent">store</span></span>
          </h1>
          <p class="hero-entry hero-desc text-base md:text-lg lg:text-xl text-white/60 max-w-xl leading-relaxed">
            Apps para tu negocio: herramientas internas, paneles de gestión y soluciones a la medida. Desde low-code hasta nativo, según lo que necesites.
          </p>
          <div class="hero-entry hero-buttons flex flex-wrap gap-3 md:gap-4 justify-center lg:justify-start">
            <a href="#proyectos" class="group inline-flex items-center gap-2 bg-gradient-to-r from-purple-500 to-teal-500 text-white font-semibold px-6 py-3 md:px-7 md:py-3 text-sm md:text-base rounded-2xl hover:shadow-lg hover:shadow-purple-500/20 hover:scale-[1.02] active:scale-[0.98] transition" data-umami-event="mobile_hero_projects_cta">
              <span>Ver proyectos</span>
              <Icon name="heroicons:arrow-right" size={16} class="group-hover:translate-x-1 transition-transform" />
            </a>
            <a href="#capacidades" class="inline-flex items-center gap-2 border border-white/15 text-white/50 px-6 py-3 md:px-7 md:py-3 text-sm md:text-base rounded-2xl hover:border-teal-400/40 hover:text-teal-300 transition" data-umami-event="mobile_hero_capabilities_cta">
              <Icon name="heroicons:sparkles" size={16} />
              Capacidades
            </a>
          </div>
        </div>

        <div class="hero-entry hero-phone hidden lg:flex items-center justify-center shrink-0">
          <div class="phone-frame relative group animate-float">
            <!-- Glow aura -->
            <div class="absolute -inset-8 rounded-[76px] bg-gradient-to-br from-purple-500/20 via-teal-400/10 to-pink-500/20 blur-2xl opacity-60 animate-glow-pulse pointer-events-none"></div>
            <div class="phone-notch"></div>
            <div class="phone-screen">
              <!-- Page 1: Home (default) -->
              <div class="absolute inset-0 transition duration-500 group-hover:opacity-0 group-hover:scale-95 z-10">
                <div class="h-full w-full bg-gradient-to-br from-[#1a1a2e] via-[#16213e] to-dark-surface flex flex-col">
                  <!-- Status bar -->
                  <div class="flex items-center justify-between px-5 pt-4 pb-1">
                    <span class="text-[9px] text-white/60 font-semibold tracking-tight">9:41</span>
                    <div class="flex items-center gap-1.5">
                      <div class="w-3.5 h-2 rounded-[2px] bg-white/10 border border-white/10 relative overflow-hidden">
                        <div class="absolute inset-[1.5px] right-[3px] rounded-[1px] bg-gradient-to-r from-purple-400 to-teal-400"></div>
                        <div class="absolute right-[2px] top-[3px] w-[2px] h-[4px] rounded-r-sm border-r border-t border-b border-white/20"></div>
                      </div>
                      <svg class="w-3.5 h-2.5 text-white/50" viewBox="0 0 18 12" fill="none"><path d="M1 7C1 5.89543 1.89543 5 3 5H4V7C4 8.10457 3.10457 9 2 9H1V7Z" fill="currentColor"/><path d="M5 3C5 1.89543 5.89543 1 7 1H8V6C8 7.10457 7.10457 8 6 8H5V3Z" fill="currentColor"/><path d="M9 2C9 0.895431 9.89543 0 11 0H12V8C12 9.10457 11.1046 10 10 10H9V2Z" fill="currentColor"/></svg>
                    </div>
                  </div>
                  <!-- Header: Avatar + Greeting -->
                  <div class="flex items-center justify-between px-5 py-2">
                    <div class="flex items-center gap-2.5">
                      <div class="w-7 h-7 rounded-full bg-gradient-to-br from-purple-500 to-teal-500 flex items-center justify-center text-[9px] font-bold text-white shadow-lg shadow-purple-500/30">O</div>
                      <div>
                        <span class="text-[7px] text-white/30">Buenos días</span>
                        <span class="text-[10px] text-white/80 font-semibold block -mt-0.5">Cliente</span>
                      </div>
                    </div>
                    <div class="relative">
                      <div class="w-6 h-6 rounded-xl bg-white/5 border border-white/5 flex items-center justify-center">
                        <Icon name="heroicons:bell" size={10} class="text-white/50" />
                      </div>
                      <div class="absolute -top-0.5 -right-0.5 w-2 h-2 rounded-full bg-pink-400 border border-[#1a1a2e]"></div>
                    </div>
                  </div>
                  <!-- Stats row -->
                  <div class="flex gap-2 px-5 py-1.5">
                    {[{v: '12', l: 'Activos'}, {v: '48', l: 'Completados'}, {v: '4.9', l: 'Rating'}].map(s => (
                      <div class="flex-1 rounded-xl bg-white/[0.03] border border-white/[0.04] px-2.5 py-1.5">
                        <span class="text-[11px] font-bold text-white/80">{s.v}</span>
                        <span class="text-[6px] text-white/25 block leading-tight">{s.l}</span>
                      </div>
                    ))}
                  </div>
                  <!-- Filter chips -->
                  <div class="flex gap-1.5 px-5 py-1.5 overflow-hidden">
                    {['Todos', 'Diseño', 'Dev', 'QA'].map((chip, i) => (
                      <div class={`px-2.5 py-1 rounded-full text-[7px] font-medium ${i === 0 ? 'bg-purple-500/30 text-purple-200 border border-purple-400/30' : 'bg-white/[0.04] text-white/30 border border-white/[0.04]'}`}>{chip}</div>
                    ))}
                  </div>
                  <!-- List -->
                  <div class="flex-1 flex flex-col gap-2 px-5 py-1.5 overflow-hidden">
                    {[
                      {n: 'ui', t: 'Rediseño Dashboard', s: '18 tareas', c: 'bg-purple-400/20 border-purple-400/30', ic: 'text-purple-300', i: 'paint-brush'},
                      {n: 'dev', t: 'Login biométrico', s: '7 tareas', c: 'bg-teal-400/20 border-teal-400/30', ic: 'text-teal-300', i: 'finger-print'},
                      {n: 'qa', t: 'Tests E2E', s: '12 tareas', c: 'bg-pink-400/20 border-pink-400/30', ic: 'text-pink-300', i: 'bug-ant'},
                    ].map((item) => (
                      <div class="flex items-center gap-2.5 px-2.5 py-2 rounded-2xl bg-white/[0.03] border border-white/[0.04] hover:bg-white/[0.06] transition-colors cursor-default">
                        <div class={`w-7 h-7 rounded-xl ${item.c} flex items-center justify-center shrink-0`}>
                          <Icon name={`heroicons:${item.i}`} size={10} class={item.ic} />
                        </div>
                        <div class="flex-1 min-w-0">
                          <span class="text-[8px] text-white/80 font-medium block truncate">{item.t}</span>
                          <span class="text-[6px] text-white/25">{item.s}</span>
                        </div>
                        <div class="flex items-center gap-1.5">
                          <div class="w-1 h-1 rounded-full bg-green-400/60"></div>
                          <span class="text-[6px] text-white/20">Ahora</span>
                        </div>
                      </div>
                    ))}
                  </div>
                  <!-- Bottom nav -->
                  <div class="flex items-center justify-around px-4 py-2 border-t border-white/[0.04]">
                    {[{i: 'home', l: 'Inicio'}, {i: 'folder', l: 'Proyectos'}, {i: 'chart-bar-square', l: 'Stats'}, {i: 'cog-6-tooth', l: 'Ajustes'}].map((tab, i) => (
                      <div class="flex flex-col items-center gap-0.5">
                        <div class={`w-5 h-5 rounded-lg flex items-center justify-center ${i === 1 ? 'bg-purple-400/20' : ''}`}>
                          <Icon name={`heroicons:${tab.i}`} size={10} class={i === 1 ? 'text-purple-300' : 'text-white/20'} />
                        </div>
                        <span class={`text-[5px] ${i === 1 ? 'text-purple-300/70' : 'text-white/15'}`}>{tab.l}</span>
                      </div>
                    ))}
                  </div>
                  <!-- Gesture bar -->
                  <div class="flex justify-center py-2">
                    <div class="w-16 h-1 rounded-full bg-white/15"></div>
                  </div>
                </div>
              </div>
              <!-- Page 2: Detail (on hover) -->
              <div class="absolute inset-0 opacity-0 transition duration-500 group-hover:opacity-100 group-hover:scale-100 scale-95">
                <div class="h-full w-full bg-gradient-to-br from-[#1a1a2e] via-[#1e1028] to-dark-surface flex flex-col">
                  <!-- Status bar -->
                  <div class="flex items-center justify-between px-5 pt-4 pb-1">
                    <span class="text-[9px] text-white/60 font-semibold tracking-tight">9:41</span>
                    <div class="flex items-center gap-1.5">
                      <div class="w-3.5 h-2 rounded-[2px] bg-white/10 border border-white/10 relative overflow-hidden">
                        <div class="absolute inset-[1.5px] right-[3px] rounded-[1px] bg-gradient-to-r from-purple-400 to-teal-400"></div>
                      </div>
                      <svg class="w-3.5 h-2.5 text-white/50" viewBox="0 0 18 12" fill="none"><path d="M1 7C1 5.89543 1.89543 5 3 5H4V7C4 8.10457 3.10457 9 2 9H1V7Z" fill="currentColor"/><path d="M5 3C5 1.89543 5.89543 1 7 1H8V6C8 7.10457 7.10457 8 6 8H5V3Z" fill="currentColor"/><path d="M9 2C9 0.895431 9.89543 0 11 0H12V8C12 9.10457 11.1046 10 10 10H9V2Z" fill="currentColor"/></svg>
                    </div>
                  </div>
                  <!-- Back bar -->
                  <div class="flex items-center gap-1 px-4 py-2">
                    <div class="w-5 h-5 rounded-lg bg-white/5 flex items-center justify-center">
                      <Icon name="heroicons:chevron-left" size={9} class="text-white/50" />
                    </div>
                    <span class="text-[8px] text-white/50 ml-1">Volver</span>
                    <div class="flex-1"></div>
                    <div class="w-5 h-5 rounded-lg bg-white/5 flex items-center justify-center">
                      <Icon name="heroicons:ellipsis-horizontal" size={9} class="text-white/50" />
                    </div>
                  </div>
                  <!-- Hero Image -->
                  <div class="mx-4 h-[90px] rounded-2xl bg-gradient-to-br from-purple-600/30 via-teal-500/20 to-pink-500/30 border border-white/[0.04] flex items-center justify-center overflow-hidden relative">
                    <div class="absolute inset-0 bg-gradient-to-t from-[#1a1a2e]/80 to-transparent"></div>
                    <Icon name="heroicons:rectangle-group" size={20} class="text-white/10" />
                    <div class="absolute bottom-2 left-3">
                      <span class="text-[8px] text-white/70 font-semibold">Dashboard</span>
                      <span class="text-[6px] text-white/25 block">Rediseño UI</span>
                    </div>
                  </div>
                  <!-- Content area -->
                  <div class="flex-1 flex flex-col px-5 py-2 gap-2">
                    <!-- Progress section -->
                    <div>
                      <div class="flex items-center justify-between mb-1">
                        <span class="text-[7px] text-white/50 font-medium">Progreso</span>
                        <span class="text-[7px] text-white/60 font-semibold">12/18</span>
                      </div>
                      <div class="h-1.5 rounded-full bg-white/[0.05] overflow-hidden">
                        <div class="h-full w-[66%] rounded-full bg-gradient-to-r from-purple-500 to-teal-400"></div>
                      </div>
                    </div>
                    <!-- Two stat cards -->
                    <div class="flex gap-2">
                      <div class="flex-1 rounded-xl bg-white/[0.03] border border-white/[0.04] px-3 py-2">
                        <span class="text-[9px] text-purple-300 font-bold">3</span>
                        <span class="text-[6px] text-white/25 block leading-tight">En revisión</span>
                      </div>
                      <div class="flex-1 rounded-xl bg-white/[0.03] border border-white/[0.04] px-3 py-2">
                        <span class="text-[9px] text-teal-300 font-bold">5</span>
                        <span class="text-[6px] text-white/25 block leading-tight">Completadas</span>
                      </div>
                    </div>
                    <!-- Tags -->
                    <div class="flex flex-wrap gap-1.5 mt-1">
                      {['Figma', 'Tailwind', 'React', 'TS'].map(t => (
                        <span class="px-2 py-0.5 rounded-full bg-white/[0.04] border border-white/[0.04] text-[6px] text-white/30">{t}</span>
                      ))}
                    </div>
                    <!-- Activity feed -->
                    <div class="mt-1 space-y-1.5">
                      <span class="text-[7px] text-white/30 font-medium">Actividad</span>
                      {[{d: 'Ayer', t: 'Comentarios revisados'}, {d: 'Hoy', t: 'Header actualizado'}].map(a => (
                        <div class="flex items-start gap-2">
                          <div class="w-1.5 h-1.5 rounded-full bg-purple-400/50 mt-1"></div>
                          <div>
                            <span class="text-[7px] text-white/60">{a.t}</span>
                            <span class="text-[5px] text-white/20 block">{a.d}</span>
                          </div>
                        </div>
                      ))}
                    </div>
                  </div>
                  <!-- Bottom action -->
                  <div class="px-5 pb-3">
                    <div class="w-full py-2 rounded-2xl bg-gradient-to-r from-purple-500/30 to-teal-500/30 border border-purple-400/30 flex items-center justify-center gap-1.5">
                      <Icon name="heroicons:arrow-up-circle" size={8} class="text-purple-300" />
                      <span class="text-[7px] text-white/60 font-medium">Actualizar estado</span>
                    </div>
                  </div>
                  <!-- Gesture bar -->
                  <div class="flex justify-center pb-2">
                    <div class="w-16 h-1 rounded-full bg-white/15"></div>
                  </div>
                </div>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>


  <!-- Projects -->
  <section id="proyectos" class="py-24 md:py-32 bg-white/[0.01] border-y border-white/5 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-purple-500/[0.01] via-transparent to-teal-500/[0.01] pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-400/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-24 lg:h-32 bg-gradient-to-t from-dark-surface to-transparent pointer-events-none"></div>
    <div class="container-section">
      <div class="relative">
        <div class="absolute -top-20 -left-20 w-72 h-72 bg-purple-500/[0.03] rounded-full blur-[100px] pointer-events-none"></div>
        <div class="flex flex-col md:flex-row md:items-end md:justify-between gap-6">
          <div>
            <p class="text-xs text-purple-400/60 font-mono tracking-[0.25em] uppercase mb-4">Proyectos</p>
            <h2 class="text-3xl md:text-4xl font-bold text-white">
              Apps en <span class="bg-gradient-to-r from-purple-400 to-teal-400 bg-clip-text text-transparent">acción</span>
            </h2>
            <p class="text-white/60 mt-3 max-w-lg">Aplicaciones móviles que he construido.</p>
          </div>
          <a href={withBase('/projects')} class="text-sm text-white/50 hover:text-white transition-colors flex items-center gap-1 shrink-0" data-umami-event="mobile_projects_header_view_all">
            Ver todos <Icon name="heroicons:arrow-right" size={12} />
          </a>
        </div>
      </div>

      {featuredProject && (
        <div class="mt-12 space-y-6">
          <a href={withBase(`/projects/${featuredProject.id}`)} class="featured-card group block p-8 rounded-3xl bg-white/[0.02] border border-white/5 hover:border-purple-400/30 transition relative overflow-hidden" data-umami-event="mobile_latest_project_click" data-umami-event-project={featuredProject.id}>
            <div class="absolute inset-0 bg-gradient-to-br from-purple-500/[0.03] to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
            <CardGlow />
            <div class="relative z-10 flex flex-col md:flex-row gap-8 items-start">
              <div class="w-full md:w-1/2 aspect-video rounded-2xl bg-white/[0.03] border border-white/5 flex items-center justify-center overflow-hidden">
                {featuredProject.images?.[0] ? (
                  featuredProject.images[0].src ? (
                    <img src={withBase(featuredProject.images[0].src)} alt={featuredProject.images[0].label} class="h-full w-full object-cover" />
                  ) : (
                    <div class="text-center">
                      <div class="w-14 h-14 mx-auto rounded-xl flex items-center justify-center" style={`background: ${featuredProject.images[0].color}15; border: 1px solid ${featuredProject.images[0].color}20`}>
                        <Icon name="heroicons:photo" class="w-7 h-7" style={`color: ${featuredProject.images[0].color}`} />
                      </div>
                      <p class="text-xs text-white/50 mt-2 font-medium">{featuredProject.images[0].label}</p>
                    </div>
                  )
                ) : (
                  <Icon name="heroicons:device-phone-mobile" class="w-10 h-10 text-white/10" />
                )}
              </div>
              <div class="w-full md:w-1/2">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-purple-500/10 border border-purple-400/20 text-xs text-purple-300 mb-4">
                  <span class="w-1.5 h-1.5 rounded-full bg-purple-400"></span>
                  Proyecto destacado
                </div>
                <span class="text-xs font-semibold tracking-widest text-purple-400/60 uppercase">{featuredProject.category}</span>
                {featuredProject.client && <p class="text-xs text-white/40 mt-1">{featuredProject.client}</p>}
                <h3 class="text-2xl font-bold text-white group-hover:text-purple-300 transition-colors mt-2 mb-3">{featuredProject.title}</h3>
                <p class="text-white/50 text-sm leading-relaxed">{featuredProject.description}</p>
                <div class="flex flex-wrap gap-2 mt-5">
                  {(featuredProject.tags ?? []).slice(0, 4).map((tag) => (
                    <span class="text-[11px] text-white/50 bg-white/5 border border-white/5 px-2.5 py-1 rounded-lg whitespace-nowrap">{tag}</span>
                  ))}
                  {(featuredProject.tags ?? []).length > 4 && (
                    <span class="text-[11px] text-white/50 px-2.5 py-1">+{(featuredProject.tags ?? []).length - 4}</span>
                  )}
                </div>
                <div class="flex items-center gap-2 mt-6 text-sm text-purple-300 group-hover:gap-3 transition-all">
                  <span>Ver proyecto</span>
                  <Icon name="heroicons:arrow-right" class="w-4 h-4" />
                </div>
              </div>
            </div>
          </a>
          {secondaryMobileProjects.length > 0 && (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              {secondaryMobileProjects.map((p) => <ProjectCard project={p} accent="purple" />)}
            </div>
          )}
          {sortedProjects.length > 1 + secondaryMobileProjects.length && (
            <div class="text-center mt-6">
              <a href={withBase('/projects')} class="inline-flex items-center gap-2 border border-white/15 text-white/60 px-7 py-3 rounded-xl text-sm hover:border-purple-400/40 hover:text-purple-300 transition" data-umami-event="mobile_view_more_projects">
                Ver más proyectos
                <Icon name="heroicons:arrow-right" size={16} />
              </a>
            </div>
          )}
        </div>
      )}
      {!featuredProject && (
        <div class="flex flex-col items-center justify-center mt-16 py-20 border border-white/5 rounded-3xl bg-white/[0.01]">
          <div class="w-16 h-16 rounded-2xl bg-white/[0.03] border border-white/5 flex items-center justify-center mb-5">
            <Icon name="heroicons:device-phone-mobile" size={32} class="text-white/10" />
          </div>
          <p class="text-white/30 text-sm">Próximamente proyectos móviles</p>
          <p class="text-white/15 text-xs mt-1">Estoy trabajando en algo nuevo ✨</p>
        </div>
      )}
      <div class="flex flex-col sm:flex-row items-center justify-between gap-4 mt-12 pt-6 border-t border-purple-500/10">
        <p class="text-sm text-white/30 font-mono text-center sm:text-left">¿Tenés un proyecto mobile en mente?</p>
        <a href={withBase('/contact')} class="group inline-flex items-center gap-2 bg-gradient-to-r from-purple-500/10 to-teal-500/10 border border-purple-400/20 text-purple-300 hover:text-white hover:border-purple-400/40 text-sm font-medium px-5 py-2 rounded-xl transition duration-300" data-umami-event="mobile_projects_contact_cta">
          Conversemos
          <Icon name="heroicons:arrow-right" class="w-3.5 h-3.5 group-hover:translate-x-1 transition-transform" />
        </a>
      </div>
    </div>
  </section>

  <!-- Platforms -->
  <section class="py-20 md:py-32 bg-dark-surface relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-purple-500/[0.01] via-transparent to-teal-500/[0.01] pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-teal-400/20 to-transparent"></div>
    <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-white/[0.005] to-transparent pointer-events-none"></div>
    <div class="container-section">
      <SectionTitle title="Plataformas" description="Nativo cuando importa, compartido cuando suma." />
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-16">
        {platforms.map((p, i) => (
          <div class={`group relative p-6 rounded-3xl bg-gradient-to-br ${p.gradient} border ${p.border} transition duration-500 overflow-hidden ind-entry platform-card`} style={`animation-delay:${i * 0.15}s; --glow: 0 0 40px -8px ${p.shadow};`}>
            <div class={`absolute inset-0 bg-gradient-to-br ${p.glow} opacity-0 group-hover:opacity-100 transition-opacity duration-500 pointer-events-none`} aria-hidden="true"></div>
            <div class="absolute bottom-0 left-4 right-4 h-0.5 bg-gradient-to-r from-purple-400/40 to-teal-400/40 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
            <div class="relative w-11 h-11 rounded-2xl bg-gradient-to-br from-white/[0.06] to-white/[0.02] border border-white/10 flex items-center justify-center mb-4 group-hover:scale-110 group-hover:from-purple-500/20 group-hover:to-teal-500/10 group-hover:border-purple-400/30 transition duration-300 transform-gpu">
              <Icon name={p.icon} size={20} class={p.iconColor} />
            </div>
            <h3 class="relative text-lg font-semibold text-white mb-2">{p.name}</h3>
            <p class="relative text-sm text-white/50 leading-relaxed mb-4">{p.desc}</p>
            <div class="relative flex flex-wrap gap-1.5">
              {p.features.map((f) => (
                <span class="text-[10px] text-white/50 bg-white/[0.03] border border-white/5 px-2 py-1 rounded-lg">{f}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Capabilities -->
  <section id="capacidades" class="py-24 md:py-32 bg-white/[0.01] border-y border-white/5 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-teal-500/[0.01] via-transparent to-pink-500/[0.01] pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-pink-400/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-24 lg:h-32 bg-gradient-to-t from-dark-surface to-transparent pointer-events-none"></div>
    <div class="container-section">
      <SectionTitle title="Capacidades" description="De la idea a la app en producción." />
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-4 mt-16">
        {capabilities.map((c, i) => {
          const a = capabilityAccents[c.accent];
          return (
          <div class={`group relative p-6 rounded-2xl bg-white/[0.02] border border-white/5 ${a.borderHover} transition duration-500 overflow-hidden ind-entry`} style={`animation-delay:${i * 0.1}s`}>
            <CardGlow />
            <div class={`absolute bottom-0 left-4 right-4 h-0.5 bg-gradient-to-r ${a.bottomBar} scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left`}></div>
            <div class={`relative w-10 h-10 rounded-xl ${a.iconBg} flex items-center justify-center mb-4 group-hover:scale-110 transition duration-300 transform-gpu`}>
              <Icon name={c.icon} size={18} class={a.iconColor} />
            </div>
            <h3 class={`relative text-sm font-semibold text-white ${a.titleHover} transition-colors mb-1.5`}>{c.title}</h3>
            <p class="relative text-xs text-white/35 leading-relaxed">{c.desc}</p>
          </div>
          );
        })}
      </div>
    </div>
  </section>

  <!-- Toolkit -->
  <section class="py-24 md:py-32 bg-dark-surface relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-pink-500/[0.01] via-transparent to-purple-500/[0.01] pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-400/20 to-transparent"></div>
    <div class="absolute top-0 left-0 right-0 h-32 bg-gradient-to-b from-white/[0.005] to-transparent pointer-events-none"></div>
    <div class="container-section">
      <SectionTitle title="Toolkit Móvil" description="Tecnologías con las que construyo apps." />
      <div class="grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-5 gap-2 sm:gap-px sm:bg-white/[0.03] rounded-2xl sm:overflow-hidden sm:border sm:border-white/5 mt-10 sm:mt-16">
        {toolkit.map((t, i) => (
          <div class={`ind-entry group relative bg-white/[0.02] sm:bg-dark-surface border border-white/5 sm:border-0 rounded-2xl sm:rounded-none p-4 sm:p-5 hover:bg-white/[0.04] sm:hover:bg-white/[0.02] transition-colors duration-300 flex flex-col items-center justify-center text-center gap-2.5 sm:gap-3 min-h-28 sm:min-h-0 ${i === toolkit.length - 1 ? 'col-span-2 sm:col-span-1' : ''}`} style={`animation-delay:${i * 0.06}s`}>
            <div class={`absolute inset-0 bg-gradient-to-b ${t.color} opacity-0 group-hover:opacity-[0.04] transition-opacity duration-300`}></div>
            <div class="relative w-9 h-9 sm:w-10 sm:h-10 rounded-xl bg-white/[0.04] border border-white/5 flex items-center justify-center group-hover:scale-110 group-hover:border-white/20 transition duration-300">
              <Icon name={t.icon} size={18} class={`${iconColors[t.icon] || 'text-white/50'} transition-colors w-4 h-4 sm:w-[18px] sm:h-[18px]`} />
            </div>
            <span class="relative text-[11px] sm:text-xs font-medium text-white/55 group-hover:text-white/80 transition-colors leading-tight max-w-full break-words">{t.name}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Workflow -->
  <section class="py-24 md:py-32 bg-white/[0.01] border-y border-white/5 relative overflow-hidden">
    <div class="absolute inset-0 bg-gradient-to-b from-teal-500/[0.01] via-transparent to-purple-500/[0.01] pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-teal-400/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-24 lg:h-32 bg-gradient-to-t from-dark-surface to-transparent pointer-events-none"></div>
    <div class="container-section">
      <SectionTitle title="Cómo lo hago" description="De la idea a la tienda de aplicaciones." />
      <div class="grid grid-cols-2 md:grid-cols-4 gap-4 mt-16">
        {workflow.map((w, i) => (
          <div class="group relative p-6 rounded-2xl bg-white/[0.02] border border-white/5 hover:border-teal-400/30 transition duration-500 overflow-hidden ind-entry" style={`animation-delay:${i * 0.15}s`}>
            <CardGlow />
            <div class="absolute bottom-0 left-4 right-4 h-0.5 bg-gradient-to-r from-teal-400/40 to-purple-400/40 scale-x-0 group-hover:scale-x-100 transition-transform duration-500 origin-left"></div>
            <div class="relative flex items-center gap-3 mb-4">
              <span class="text-[11px] font-bold text-white/30 bg-white/[0.04] px-2.5 py-0.5 rounded-full border border-white/5">{w.step}</span>
              <div class="flex-1 h-px bg-gradient-to-r from-white/[0.06] to-transparent"></div>
            </div>
            <div class="relative w-10 h-10 rounded-xl bg-gradient-to-br from-purple-500/15 to-teal-500/5 border border-purple-500/20 flex items-center justify-center mb-3 group-hover:from-purple-500/25 group-hover:to-teal-500/10 group-hover:border-purple-400/30 group-hover:scale-110 transition duration-300 transform-gpu">
              <Icon name={w.icon} size={18} class="text-teal-300" />
            </div>
            <h4 class="relative text-sm font-semibold text-white group-hover:text-teal-300 transition-colors mb-1.5">{w.label}</h4>
            <p class="relative text-xs text-white/35 leading-relaxed">{w.desc}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="py-24 md:py-40 bg-dark-surface relative overflow-hidden border-t border-white/5">
    <div class="absolute inset-0 bg-gradient-to-b from-transparent via-purple-500/[0.02] to-teal-500/[0.02] pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[500px] h-[500px] bg-purple-500/[0.03] rounded-full blur-[150px] pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-[300px] h-[300px] bg-teal-400/[0.02] rounded-full blur-[120px] pointer-events-none"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-purple-400/30 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-teal-400/20 to-transparent"></div>
    <div class="relative z-10 max-w-3xl mx-auto px-6 md:px-8 text-center">
      <div class="cta-icon mb-6 sm:mb-8">
        <div class="w-14 h-14 sm:w-16 sm:h-16 rounded-2xl bg-gradient-to-br from-purple-500/25 to-teal-500/15 border border-purple-400/30 flex items-center justify-center mx-auto shadow-lg shadow-purple-500/10 group-hover:shadow-purple-500/20 transition duration-500">
          <Icon name="heroicons:device-phone-mobile" size={24} class="text-purple-300 sm:w-7 sm:h-7" />
        </div>
      </div>
      <p class="cta-eyebrow text-[10px] sm:text-xs text-purple-400/50 font-mono tracking-[0.3em] uppercase mb-4 sm:mb-5">¿Listo para construir?</p>
      <h2 class="cta-heading text-3xl sm:text-4xl md:text-6xl font-bold mb-5 sm:mb-6 leading-tight">
        <span class="text-white">¿Tenés una idea para una </span>
        <span class="bg-gradient-to-r from-purple-400 via-teal-400 to-pink-400 bg-clip-text text-transparent">app</span>
        <span class="text-white">?</span>
      </h2>
      <p class="cta-desc text-sm sm:text-base md:text-lg text-white/50 max-w-xl mx-auto leading-relaxed mb-8 sm:mb-10">
        Desde herramientas internas con low-code hasta apps nativas a escala. Conversemos sobre tu próximo proyecto.
      </p>
      <div class="cta-button">
        <a href={withBase('/contact')} class="group inline-flex items-center gap-2 bg-gradient-to-r from-purple-500 to-teal-500 text-white font-semibold px-7 py-3 sm:px-9 sm:py-4 text-sm sm:text-base rounded-2xl hover:shadow-2xl hover:shadow-purple-500/25 hover:scale-[1.03] active:scale-[0.97] transition duration-300" data-umami-event="mobile_final_contact_cta">
          <span>Contáctame</span>
          <Icon name="heroicons:arrow-right" size={16} class="sm:w-[18px] sm:h-[18px] group-hover:translate-x-1 group-hover:scale-110 transition duration-300" />
        </a>
      </div>
    </div>
  </section>
</MobileLayout>
