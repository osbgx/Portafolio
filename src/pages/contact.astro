---
import ContactLayout from '../layouts/ContactLayout.astro';
import SectionTitle from '../components/global/SectionTitle.astro';
import FormInput from '../components/global/FormInput.astro';
import FormTextarea from '../components/global/FormTextarea.astro';
import { Icon } from 'astro-icon/components';
import { contactInfo, socialLinks } from '../data/social';

const WEB3FORMS_ACCESS_KEY = import.meta.env.PUBLIC_WEB3FORMS_ACCESS_KEY;
const isContactFormConfigured = Boolean(WEB3FORMS_ACCESS_KEY);
const directLinks = socialLinks.map((link) => ({
  ...link,
  value: link.label === 'Email'
    ? contactInfo.email
    : link.label === 'WhatsApp'
      ? `+${contactInfo.whatsapp}`
      : link.href.replace(/^https?:\/\//, '').replace(/\/$/, ''),
}));
---

<ContactLayout title="Contacto" description="Ponte en contacto conmigo">
  <section class="pt-32 pb-24 max-w-7xl mx-auto px-6 md:px-8">
    <div class="max-w-3xl mx-auto">
      <SectionTitle title="Contacto" description="¿Tienes un proyecto en mente? ¿Quieres colaborar? Hablemos." centered={false} level="h1" />
      
      <form id="contact-form" action="https://api.web3forms.com/submit" method="POST" class="mt-12 space-y-6" data-contact-form-configured={isContactFormConfigured ? 'true' : 'false'} data-umami-event="contact_form_submit_attempt">
        <input type="hidden" name="access_key" value={WEB3FORMS_ACCESS_KEY} />
        <input type="hidden" name="from_name" value="Portfolio OSBGX" />
        <input type="checkbox" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />
        <div class="grid grid-cols-1 md:grid-cols-2 gap-6">
          <div>
            <label for="name" class="block text-white/60 text-sm mb-2">Nombre</label>
            <FormInput id="name" name="name" autocomplete="name" placeholder="Nombre completo" required />
          </div>
          <div>
            <label for="email" class="block text-white/60 text-sm mb-2">Email</label>
            <FormInput type="email" id="email" name="email" autocomplete="email" inputmode="email" placeholder="tu@email.com" required />
          </div>
        </div>
        <div>
          <label for="subject" class="block text-white/60 text-sm mb-2">Asunto</label>
          <FormInput id="subject" name="subject" autocomplete="off" placeholder="Proyecto, consulta o colaboración" required />
        </div>
        <div>
          <label for="message" class="block text-white/60 text-sm mb-2">Mensaje</label>
          <FormTextarea id="message" name="message" placeholder="Contame qué tenés en mente…" required />
        </div>
        <button
          id="contact-submit"
          type="submit"
          class="w-full bg-amber-500 text-carbon font-semibold px-8 py-3.5 rounded-xl hover:bg-amber-500/90 transition hover:shadow-xl hover:shadow-amber-500/20"
          disabled={!isContactFormConfigured}
          data-umami-event="contact_submit_click"
        >
          {isContactFormConfigured ? 'Enviar mensaje' : 'Formulario no configurado'}
        </button>
        <p id="contact-result" class="hidden rounded-xl border px-4 py-3 text-sm" aria-live="polite"></p>
      </form>

      <div class="mt-12 grid grid-cols-1 sm:grid-cols-2 gap-4" aria-label="Canales de contacto directo">
        {directLinks.map((link) => (
          link.label === 'Email' ? (
            <div class="group flex items-center gap-4 rounded-2xl border border-white/5 bg-white/[0.02] p-4 text-white/60 transition hover:border-amber-400/25 hover:bg-white/[0.04] hover:text-white">
              <a href={link.href} target="_blank" rel="noopener noreferrer" class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-white/5 bg-white/[0.03] text-amber-300/80 transition group-hover:border-amber-400/25 group-hover:text-amber-300" aria-label="Enviar email" data-umami-event="contact_direct_email">
                <Icon name={link.icon} class="h-5 w-5" />
              </a>
              <span class="min-w-0 flex-1">
                <strong class="block text-sm text-white/80">{link.label}</strong>
                <span class="block truncate text-sm">{link.value}</span>
              </span>
              <button type="button" class="copy-email-btn shrink-0 rounded-lg border border-white/5 bg-white/[0.03] px-3 py-2 text-xs font-semibold text-white/50 transition hover:border-amber-400/25 hover:text-amber-300" data-email={contactInfo.email} aria-label="Copiar email" data-umami-event="contact_copy_email_click">
                Copiar
              </button>
            </div>
          ) : (
            <a href={link.href} target="_blank" rel="noopener noreferrer" class="group flex items-center gap-4 rounded-2xl border border-white/5 bg-white/[0.02] p-4 text-white/60 transition hover:border-amber-400/25 hover:bg-white/[0.04] hover:text-white" data-umami-event={`contact_direct_${link.label.toLowerCase()}`}>
              <span class="flex h-11 w-11 shrink-0 items-center justify-center rounded-xl border border-white/5 bg-white/[0.03] text-amber-300/80 transition group-hover:border-amber-400/25 group-hover:text-amber-300">
                <Icon name={link.icon} class="h-5 w-5" />
              </span>
              <span class="min-w-0">
                <strong class="block text-sm text-white/80">{link.label}</strong>
                <span class="block truncate text-sm">{link.value}</span>
              </span>
            </a>
          )
        ))}
      </div>
    </div>
  </section>
</ContactLayout>

<script>
  const form = document.getElementById('contact-form');
  const submitBtn = document.getElementById('contact-submit');
  const result = document.getElementById('contact-result');

  if (form instanceof HTMLFormElement && submitBtn instanceof HTMLButtonElement && result instanceof HTMLParagraphElement) {
    const originalText = submitBtn.textContent?.trim() || 'Enviar mensaje';

    const setResult = (message: string, status: 'success' | 'error') => {
      result.textContent = message;
      result.classList.remove('hidden', 'border-emerald-400/20', 'bg-emerald-400/[0.06]', 'text-emerald-200', 'border-red-400/20', 'bg-red-400/[0.06]', 'text-red-200');
      if (status === 'success') {
        result.classList.add('border-emerald-400/20', 'bg-emerald-400/[0.06]', 'text-emerald-200');
      } else {
        result.classList.add('border-red-400/20', 'bg-red-400/[0.06]', 'text-red-200');
      }
    };

    form.addEventListener('submit', async (event) => {
      event.preventDefault();
      if (form.dataset.contactFormConfigured !== 'true') {
        setResult('El formulario no está configurado. Escribime directo por email o WhatsApp.', 'error');
        (window as any).umami?.track('contact_form_error', { reason: 'missing_access_key' });
        return;
      }
      result.classList.add('hidden');
      submitBtn.textContent = 'Enviando...';
      submitBtn.disabled = true;
      submitBtn.classList.add('cursor-wait', 'opacity-80');

      try {
        const response = await fetch(form.action, {
          method: 'POST',
          body: new FormData(form),
        });
        const data = await response.json();

        if (response.ok && data.success) {
          setResult('Mensaje enviado. Te respondo apenas pueda.', 'success');
          (window as any).umami?.track('contact_form_success');
          form.reset();
        } else {
          setResult(data.message || 'No se pudo enviar el mensaje. Probá de nuevo.', 'error');
          (window as any).umami?.track('contact_form_error', { reason: 'api' });
        }
      } catch {
        setResult('Hubo un problema de conexión. Probá de nuevo o escribime directo por email.', 'error');
        (window as any).umami?.track('contact_form_error', { reason: 'network' });
      } finally {
        submitBtn.textContent = originalText;
        submitBtn.disabled = false;
        submitBtn.classList.remove('cursor-wait', 'opacity-80');
      }
    });
  }

  document.querySelectorAll('.copy-email-btn').forEach((button) => {
    if (!(button instanceof HTMLButtonElement) || button.dataset.copyGuard) return;
    button.dataset.copyGuard = '1';
    const originalText = button.textContent?.trim() || 'Copiar';

    button.addEventListener('click', async () => {
      const email = button.dataset.email || '';

      try {
        await navigator.clipboard.writeText(email);
        button.textContent = 'Copiado';
        (window as any).umami?.track('contact_copy_email_success');
      } catch {
        button.textContent = 'Error';
        (window as any).umami?.track('contact_copy_email_error');
      } finally {
        window.setTimeout(() => {
          button.textContent = originalText;
        }, 1600);
      }
    });
  });
</script>
