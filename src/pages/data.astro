---
import DataLayout from '../layouts/DataLayout.astro';
import StackGrid from '../components/global/StackGrid.astro';
import ProjectCard from '../components/global/ProjectCard.astro';
import { Icon } from 'astro-icon/components';
import { getCollection } from 'astro:content';
import { withBase } from '../utils/paths';
import { techStack } from '../data/tech-icons';
import type { TechCategory } from '../data/tech-icons';
import { services, pipelineSteps, metrics } from '../data/data-page';
import type { CollectionEntry } from 'astro:content';
import '../styles/data.css';

type ProjectWithId = CollectionEntry<'projects'>['data'] & { id: string };

const allProjects = (await getCollection('projects')).map((p: CollectionEntry<'projects'>) => ({ ...p.data, id: p.slug })) as ProjectWithId[];
const dataProjects = allProjects
  .filter((p: ProjectWithId) => !p.hidden)
  .filter((p: ProjectWithId) => (p.pages ?? []).includes('data'))
  .sort((a: ProjectWithId, b: ProjectWithId) => new Date(b.date).getTime() - new Date(a.date).getTime());
const mainDataProject = dataProjects[0];
const secondaryDataProjects = allProjects
  .filter((p: ProjectWithId) => !p.hidden)
  .filter((p: ProjectWithId) => (p.featuredIn ?? []).includes('data'))
  .filter((p: ProjectWithId) => p.id !== mainDataProject?.id)
  .sort((a, b) => new Date(b.date).getTime() - new Date(a.date).getTime());
const dataCategories: TechCategory[] = ['Lenguajes', 'Data & Bases de Datos', 'Herramientas', 'DevOps & Cloud'];
---

<DataLayout title="Data Engineering" description="Infraestructura de datos robusta, escalable y eficiente">
  <section class="hero-data relative min-h-[85vh] flex items-center overflow-hidden">
    <div class="scan-line"></div>
    <div class="data-grid"></div>

    <div class="data-flow" aria-hidden="true">
      <div class="flow-dot" style="top:15%;left:10%;--delay:0s;--duration:8s"></div>
      <div class="flow-dot" style="top:25%;left:30%;--delay:2s;--duration:6s"></div>
      <div class="flow-dot" style="top:45%;left:60%;--delay:4s;--duration:7s"></div>
      <div class="flow-dot" style="top:60%;left:20%;--delay:1s;--duration:9s"></div>
      <div class="flow-dot" style="top:75%;left:70%;--delay:3s;--duration:5s"></div>
      <div class="flow-dot" style="top:35%;left:80%;--delay:5s;--duration:6.5s"></div>
      <div class="flow-dot" style="top:80%;left:40%;--delay:2.5s;--duration:7.5s"></div>
      <div class="flow-dot" style="top:10%;left:55%;--delay:4.5s;--duration:8.5s"></div>
      <div class="flow-line-h" style="top:15%;left:5%;width:15%"></div>
      <div class="flow-line-h" style="top:45%;left:50%;width:20%"></div>
      <div class="flow-line-h" style="top:75%;left:20%;width:25%"></div>
      <div class="flow-line-v" style="top:5%;left:15%;height:20%"></div>
      <div class="flow-line-v" style="top:40%;left:65%;height:35%"></div>
      <div class="flow-line-v" style="top:60%;left:35%;height:25%"></div>
    </div>

    <div class="hero-chart" aria-hidden="true">
      <svg viewBox="0 0 120 60" preserveAspectRatio="none">
        <rect class="hc-bar" x="2" y="32" width="12" height="24" style="--d:0s" />
        <rect class="hc-bar" x="18" y="20" width="12" height="36" style="--d:0.3s" />
        <rect class="hc-bar" x="34" y="26" width="12" height="30" style="--d:0.6s" />
        <rect class="hc-bar" x="50" y="14" width="12" height="42" style="--d:0.9s" />
        <rect class="hc-bar" x="66" y="30" width="12" height="26" style="--d:1.2s" />
        <rect class="hc-bar" x="82" y="18" width="12" height="38" style="--d:1.5s" />
        <rect class="hc-bar" x="98" y="24" width="12" height="32" style="--d:1.8s" />
        <polyline class="hc-line" points="8,34 24,20 40,28 56,12 72,32 88,16 104,22" />
      </svg>
    </div>

    <div class="container-section py-24 w-full">
      <div class="max-w-4xl">
        <div class="terminal-badge mb-8">
          <span class="prompt-sign">$</span>
          <span id="typing-text" class="typing-text" data-text="cat /profiles/data-fullstack"></span>
          <span class="cursor-blink">_</span>
        </div>
        <script is:inline>
        (function(){
          var el = document.getElementById('typing-text');
          if (!el || el.dataset.typingGuard) return;
          el.dataset.typingGuard = '1';
          var text = el.getAttribute('data-text') || 'cat /profiles/data-fullstack';
          if (window.__osb_typingDone) { el.textContent = text; return; }
          el.textContent = '';
          var i = 0;
          (function type(){
            if (i < text.length) {
              el.textContent += text.charAt(i);
              i++;
              setTimeout(type, 50 + Math.random() * 40);
            } else {
              window.__osb_typingDone = true;
            }
          })();
        })();
        </script>
        <h1 class="hero-title text-4xl md:text-6xl font-bold mb-6 leading-tight">
          <span class="text-white/90">Data Fullstack</span><br />
          <span class="text-hylian hero-glow">El ecosistema completo de datos</span>
        </h1>
        <p class="hero-subtitle text-lg md:text-xl text-white/50 max-w-2xl leading-relaxed mb-10">
          Arquitectura, ingeniería, análisis, visualización, ML y ciencia — todo el ciclo de vida del dato.
        </p>
        <div class="flex flex-wrap gap-4">
          <a href="#servicios" class="data-btn-primary" data-umami-event="data_hero_services_cta">
            <Icon name="heroicons:bolt" size={16} />
            <span>Servicios de Data</span>
          </a>
          <a href="#proyectos" class="data-btn-secondary" data-umami-event="data_hero_projects_cta">
            <span>Ver proyectos de Data</span>
            <Icon name="heroicons:arrow-right" size={16} />
          </a>
        </div>
      </div>
    </div>
  </section>

  <section id="servicios" class="py-24 md:py-32 relative">
    <div class="section-divider top-0"></div>
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="mb-12">
        <span class="text-xs text-hylian/50 font-mono tracking-[0.2em] uppercase">// 01 — expertise</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mt-3">Qué hago con datos</h2>
        <p class="text-white/50 text-lg mt-3 max-w-2xl font-mono">Todo el espectro de datos, de la fuente al insight, del modelo a la decisión.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-5">
        {services.map((item) => (
          <div class="data-card group">
            <div class="data-card-glow"></div>
            <div class="relative z-10">
              <div class="data-icon-box">
                <Icon name={`heroicons:${item.icon}`} size={20} class="text-hylian" />
              </div>
              <h3 class="data-card-title">{item.title}</h3>
              <p class="data-card-desc">{item.desc}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section id="proyectos" class="py-24 md:py-32 relative bg-white/[0.01]">
    <div class="section-divider top-0"></div>
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="mb-12">
        <span class="text-xs text-hylian/50 font-mono tracking-[0.2em] uppercase">// 02 — proyectos</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mt-3">Proyectos de Datos</h2>
        <p class="text-white/50 text-lg mt-3 max-w-2xl font-mono">Proyectos que abarcan ingeniería, análisis y ciencia de datos.</p>
      </div>
      {mainDataProject && (
        <div class="mt-12 space-y-5">
          <a href={withBase(`/projects/${mainDataProject.id}`)} class="featured-card group block p-8 bg-white/[0.02] border border-white/5 hover:border-hylian/20 transition relative overflow-hidden" data-umami-event="data_latest_project_click" data-umami-event-project={mainDataProject.id}>
            <div class="absolute inset-0 bg-gradient-to-br from-hylian/[0.03] to-transparent opacity-0 group-hover:opacity-100 transition-opacity pointer-events-none"></div>
            <div class="relative z-10 flex flex-col md:flex-row gap-8 items-start">
              <div class="w-full md:w-1/2 aspect-video bg-white/[0.03] border border-white/5 flex items-center justify-center overflow-hidden">
                {mainDataProject.images?.[0] ? (
                  mainDataProject.images[0].src ? (
                    <img src={withBase(mainDataProject.images[0].src)} alt={mainDataProject.images[0].label} class="h-full w-full object-cover" />
                  ) : (
                    <div class="text-center">
                      <div class="w-14 h-14 mx-auto rounded-xl flex items-center justify-center" style={`background: ${mainDataProject.images[0].color}15; border: 1px solid ${mainDataProject.images[0].color}20`}>
                        <Icon name="heroicons:photo" class="w-7 h-7" style={`color: ${mainDataProject.images[0].color}`} />
                      </div>
                      <p class="text-xs text-white/50 mt-2 font-medium">{mainDataProject.images[0].label}</p>
                    </div>
                  )
                ) : (
                  <Icon name="heroicons:photo" class="w-10 h-10 text-white/10" />
                )}
              </div>
              <div class="w-full md:w-1/2">
                <div class="inline-flex items-center gap-2 px-3 py-1 rounded-full bg-hylian/10 border border-hylian/20 text-xs text-hylian mb-4">
                  <span class="w-1.5 h-1.5 rounded-full bg-hylian"></span>
                  Proyecto destacado
                </div>
                <span class="text-xs font-semibold tracking-widest text-hylian uppercase">{mainDataProject.category}</span>
                {mainDataProject.client && <p class="text-xs text-white/40 mt-1">{mainDataProject.client}</p>}
                <h3 class="text-2xl font-bold text-white group-hover:text-hylian transition-colors mt-2 mb-3">{mainDataProject.title}</h3>
                <p class="text-desc">{mainDataProject.description}</p>
                <div class="flex flex-wrap gap-2 mt-5">
                  {(mainDataProject.tags ?? []).slice(0, 4).map((tag: string) => (
                    <span class="text-[11px] text-white/50 bg-white/5 border border-white/5 px-2.5 py-1 rounded-full whitespace-nowrap">{tag}</span>
                  ))}
                  {(mainDataProject.tags ?? []).length > 4 && (
                    <span class="text-[11px] text-white/50 px-2.5 py-1">+{(mainDataProject.tags ?? []).length - 4}</span>
                  )}
                </div>
                <div class="flex items-center gap-2 mt-6 text-sm text-hylian group-hover:gap-3 transition-all font-mono">
                  <span>Ver proyecto</span>
                  <Icon name="heroicons:arrow-right" class="w-4 h-4" />
                </div>
              </div>
            </div>
          </a>
          {secondaryDataProjects.length > 0 && (
            <div class="grid grid-cols-1 md:grid-cols-2 gap-5">
              {secondaryDataProjects.map((p) => (
                <div class="data-project-card group">
                  <ProjectCard project={p} square />
                </div>
              ))}
            </div>
          )}
        </div>
      )}
      {dataProjects.length > 1 + secondaryDataProjects.length && (
        <div class="mt-10 text-center">
          <a href={withBase('/projects')} class="data-btn-secondary inline-flex" data-umami-event="data_view_more_projects">
            <span>Ver más proyectos</span>
            <Icon name="heroicons:arrow-right" size={16} />
          </a>
        </div>
      )}
      <div class="flex items-center justify-between mt-12 pt-6 border-t border-hylian/10">
        <p class="text-sm text-white/30 font-mono">¿Tienes un proyecto de datos en mente?</p>
        <a href={withBase('/contact')} class="text-sm text-hylian/70 hover:text-hylian transition-colors inline-flex items-center gap-1.5 group font-mono" data-umami-event="data_projects_contact_cta">
          hablemos
          <Icon name="heroicons:arrow-right" class="w-3.5 h-3.5 group-hover:translate-x-0.5 transition-transform" />
        </a>
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 relative bg-white/[0.01]">
    <div class="section-divider top-0"></div>
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="mb-12">
        <span class="text-xs text-hylian/50 font-mono tracking-[0.2em] uppercase">// 03 — stack</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mt-3">Mi stack de datos</h2>
        <p class="text-white/50 text-lg mt-3 max-w-2xl font-mono">Tecnologías que uso para construir infraestructura de datos sólida.</p>
      </div>
      <div class="mt-12 space-y-10">
        {dataCategories.map((cat) => (
          <StackGrid items={techStack} category={cat} square />
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 relative">
    <div class="section-divider top-0"></div>
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="mb-12">
        <span class="text-xs text-hylian/50 font-mono tracking-[0.2em] uppercase">// 04 — proceso</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mt-3">Mi flujo de trabajo fullstack</h2>
        <p class="text-white/50 text-lg mt-3 max-w-2xl font-mono">Del problema de negocio al modelo en producción, pasando por cada capa del dato.</p>
      </div>

      <div class="relative mt-16 pipeline-timeline">
        <div class="pipeline-track" aria-hidden="true">
          <div class="pipeline-flow"></div>
        </div>

        {pipelineSteps.map((item) => (
          <div class="pipeline-step group">
            <div class="pipeline-node">
              <div class="pipeline-dot"></div>
              <div class="pipeline-glow"></div>
            </div>
            <div class="pipeline-content">
              <div class="pipeline-card">
                <div class="flex items-center gap-4 mb-4">
                  <div class="w-10 h-10 rounded-md bg-hylian/10 border border-hylian/20 flex items-center justify-center shrink-0">
                    <Icon name={`heroicons:${item.icon}`} size={18} class="text-hylian" />
                  </div>
                  <div>
                    <span class="text-xs text-hylian/60 font-mono">{item.step}</span>
                    <h3 class="text-lg font-semibold text-white">{item.title}</h3>
                  </div>
                </div>
                <p class="text-desc">{item.desc}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 relative">
    <div class="section-divider top-0"></div>
    <div class="max-w-7xl mx-auto px-6 md:px-8">
      <div class="mb-12">
        <span class="text-xs text-hylian/50 font-mono tracking-[0.2em] uppercase">// 05 — métricas</span>
        <h2 class="text-3xl md:text-4xl font-bold text-white mt-3">Resultados</h2>
        <p class="text-white/50 text-lg mt-3 max-w-2xl font-mono">Datos que transforman negocios, en cada capa del stack.</p>
      </div>
      <div class="grid grid-cols-1 md:grid-cols-3 gap-5 mt-12">
        {metrics.map((metric) => (
          <div class="data-metric-card group">
            <div class="data-metric-glow"></div>
            <div class="relative z-10 text-center">
              <div class="w-14 h-14 rounded-lg bg-hylian/10 border border-hylian/20 flex items-center justify-center mx-auto mb-5 group-hover:scale-110 transition-transform duration-300">
                <Icon name={`heroicons:${metric.icon}`} size={24} class="text-hylian" />
              </div>
              <p class="text-5xl md:text-6xl font-bold text-hylian mb-2 metric-value font-mono">{metric.value}</p>
              <p class="text-white/50 text-xs leading-relaxed uppercase tracking-[0.15em] font-mono">{metric.label}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-24 md:py-32 relative bg-white/[0.01]">
    <div class="section-divider top-0"></div>
    <div class="max-w-4xl mx-auto px-6 md:px-8 text-center">
      <div class="mb-6">
        <span class="text-xs text-hylian/50 font-mono tracking-[0.2em] uppercase">// 06 — contacto</span>
      </div>
      <h2 class="text-3xl md:text-4xl font-bold text-white mb-6">¿Necesitas a alguien que domine todo el ecosistema de datos?</h2>
      <p class="text-lg text-white/50 max-w-xl mx-auto leading-relaxed mb-10 font-mono">
        Si necesitás pipelines, dashboards, modelos o automatizaciones — o todo junto — puedo ayudarte a lo largo de todo el ciclo del dato.
      </p>
      <a href={withBase('/contact')} class="data-btn-primary inline-flex" data-umami-event="data_final_contact_cta">
        <span>Contáctame</span>
        <Icon name="heroicons:arrow-right" size={16} />
      </a>
    </div>
  </section>
</DataLayout>


