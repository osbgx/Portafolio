        ))}
      </div>
    </div>
  </section>

  <section data-reveal class="section section-subtle" aria-labelledby="cta-heading">
    <div class="absolute inset-0 bg-gradient-to-b from-amber-500/[0.02] via-transparent to-amber-500/[0.02] pointer-events-none"></div>
    <div class="absolute top-1/2 left-1/4 w-72 h-72 bg-amber-500/5 rounded-full blur-[120px] pointer-events-none animate-glow-drift"></div>
    <div class="absolute bottom-1/4 right-1/4 w-48 h-48 bg-amber-500/[0.03] rounded-full blur-[100px] pointer-events-none animate-glow-drift" style="animation-delay: -3s;"></div>
    <div class="absolute top-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-amber-500/20 to-transparent"></div>
    <div class="absolute bottom-0 left-0 right-0 h-px bg-gradient-to-r from-transparent via-amber-500/10 to-transparent"></div>

    <div class="relative max-w-4xl mx-auto px-6 md:px-8 text-center">
      <h2 id="cta-heading" class="font-bold text-white mb-6" style="font-size: clamp(1.25rem, 4.5vw, 3rem);">
        ¿Trabajamos <span class="whitespace-nowrap">juntos?<span class="inline-block animate-heading-pulse"></span></span>
      </h2>
      <p class="text-lg text-white/50 max-w-xl mx-auto leading-relaxed mb-10">
        Estoy disponible para proyectos freelance, consultoría y colaboraciones interesantes.
      </p>
      <a href={withBase('/contact')} class="group relative inline-flex items-center gap-2 bg-amber-500 text-white font-semibold px-8 py-3.5 rounded-xl hover:bg-amber-500/90 transition hover:shadow-xl hover:shadow-amber-500/20 overflow-hidden" data-umami-event="home_final_contact_cta">
        <span class="absolute inset-0 bg-gradient-to-r from-transparent via-white/10 to-transparent -skew-x-12 translate-x-[-200%] group-hover:translate-x-[200%] transition-transform duration-700"></span>
        <span class="relative">Empecemos</span>
        <Icon name="heroicons:arrow-right" class="w-4 h-4 relative group-hover:translate-x-1 transition-transform" />
      </a>
    </div>
  </section>
</HomeLayout>

<script>
  document.addEventListener('astro:page-load', () => {
    function toggleExp(idx: number) {
      const card = document.querySelector(`.exp-card[data-index="${idx}"]`);
      const wrapper = card?.parentElement;
      const extra = wrapper?.querySelector('.exp-extra') as HTMLElement | null;
      const chevron = wrapper?.querySelector('.exp-chevron');
      const dot = document.querySelector(`.exp-dot[data-index="${idx}"]`);
      if (!card || !extra || !chevron) return;
      const isOpen = extra.style.maxHeight && extra.style.maxHeight !== '0px';
      if (isOpen) {
        extra.style.overflow = 'hidden';
        extra.style.maxHeight = '0';
      } else {
        extra.style.maxHeight = extra.scrollHeight + 'px';
        const onEnd = () => {
          extra.style.overflow = '';
          extra.removeEventListener('transitionend', onEnd);
        };
        extra.addEventListener('transitionend', onEnd);
      }
      chevron.classList.toggle('chevron-open');
      if (dot) {
        dot.classList.toggle('exp-active');
        dot.setAttribute('aria-expanded', String(!isOpen));
      }
      card.setAttribute('aria-expanded', String(!isOpen));
    }

    document.querySelectorAll('.exp-card').forEach((card) => {
      const cardEl = card as HTMLElement;
      if (cardEl.dataset.expGuard) return;
      cardEl.dataset.expGuard = '1';
      cardEl.addEventListener('click', () => toggleExp(Number(cardEl.dataset.index)));
      card.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          toggleExp(Number(cardEl.dataset.index));
        }
      });
    });
    document.querySelectorAll('.exp-dot').forEach((dot) => {
      const dotEl = dot as HTMLElement;
      if (dotEl.dataset.expGuard) return;
      dotEl.dataset.expGuard = '1';
      dotEl.addEventListener('click', () => toggleExp(Number(dotEl.dataset.index)));
      dot.addEventListener('keydown', (e) => {
        if ((e as KeyboardEvent).key === 'Enter' || (e as KeyboardEvent).key === ' ') {
          e.preventDefault();
          toggleExp(Number(dotEl.dataset.index));
        }
      });
    });

    const heroGlow = document.getElementById('hero-glow');
    const hero = heroGlow?.parentElement;
    if (heroGlow && hero && !hero.dataset.mousemoveActive) {
      hero.dataset.mousemoveActive = 'true';
      let ticking = false;
      hero.addEventListener('mousemove', (e) => {
        if (!ticking) {
          requestAnimationFrame(() => {
            const rect = hero.getBoundingClientRect();
            const x = ((e.clientX - rect.left) / rect.width) * 100;
            const y = ((e.clientY - rect.top) / rect.height) * 100;
            heroGlow.style.background = `radial-gradient(350px at ${x}% ${y}%, rgba(251,191,36,0.06), transparent 60%)`;
            ticking = false;
          });
          ticking = true;
        }
      });
    }
  });
</script>


